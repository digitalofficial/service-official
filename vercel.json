{
  "buildCommand": "pnpm turbo run build --filter=@service-official/web",
  "outputDirectory": "apps/web/.next",
  "installCommand": "pnpm install --filter=@service-official/web... --filter=@service-official/database... --no-frozen-lockfile",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/send-reminders",
      "schedule": "0 6 * * *"
    }
  ]
}
