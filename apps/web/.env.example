# ============================================================
# SERVICE OFFICIAL — Environment Variables
# Copy this to .env.local and fill in your values
# ============================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Service Official"

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs
STRIPE_PRICE_SOLO_MONTHLY=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...

# ── Twilio (SMS) ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ── Resend (Email) ────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@serviceofficial.com
EMAIL_FROM_NAME="Service Official"

# ── Anthropic (AI Takeoffs) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Maps (Routing / Dispatch) ─────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=...

# ── AWS S3 (Optional - Document Storage Backup) ──────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=service-official-docs

# ── Push Notifications ────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
