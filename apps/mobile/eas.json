{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "node": "20.18.0",
      "installCommand": "cd apps/mobile && npm install --legacy-peer-deps"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "node": "20.18.0",
      "installCommand": "cd apps/mobile && npm install --legacy-peer-deps"
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "buildConfiguration": "Release"
      },
      "node": "20.18.0",
      "installCommand": "cd apps/mobile && npm install --legacy-peer-deps"
    }
  }
}
